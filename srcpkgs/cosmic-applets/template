# Template file for 'cosmic-applets'
pkgname=cosmic-applets
version=1.0.14
revision=1
build_style=cargo
_epoch_tag="epoch-${version}"
distfiles="https://github.com/pop-os/cosmic-applets/archive/refs/tags/${_epoch_tag}.tar.gz"
checksum=0b2813fdb18b0f84188cf40b8be1aae59d181da40fdfabcdc90558336d09482a

short_desc="COSMIC panel applets (battery, network, audio, etc.)"
maintainer="Maintainer <maintainer@example.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/pop-os/cosmic-applets"

hostmakedepends="pkg-config cargo rust"
makedepends="
 wayland-devel
 libxkbcommon-devel
 dbus-devel
 pipewire-devel
 pulseaudio-devel
 NetworkManager-devel
 eudev-libudev-devel
"
depends="dbus pipewire NetworkManager"

_applets="
 cosmic-app-list
 cosmic-applet-audio
 cosmic-applet-battery
 cosmic-applet-bluetooth
 cosmic-applet-network
 cosmic-applet-notifications
 cosmic-applet-power
 cosmic-applet-time
 cosmic-applet-workspaces
"

do_install() {
	for _applet in ${_applets}; do
		[ -f "target/release/${_applet}" ] && vbin "target/release/${_applet}"
	done
	vlicense LICENSE
}
